 org.eclipse.jdt.junit,
 org.eclipse.jdt.launching,
 org.eclipse.pde.launching,
 org.eclipse.pde.ui,
 org.eclipse.ui,
 org.eclipse.jface
Bundle-RequiredExecutionEnvironment: JavaSE-17
Bundle-ActivationPolicy: lazy
